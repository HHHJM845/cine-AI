# suxi 文本能力（图生文 + Prompt 优化）
SUXI_BASE_URL="https://new.suxi.ai/v1"
SUXI_API_KEY=""
SUXI_VISION_MODEL="gpt-4o-mini"
SUXI_TEXT_MODEL="deepseek-v3"

# 后端 API 端口（可选，默认 8787）
API_PORT="8787"

# 应用 URL（可选，部署时可使用）
APP_URL="MY_APP_URL"

# 生成历史 SQLite 文件路径
SQLITE_PATH="storage/cine.db"

# 生成图片本地存储目录
GENERATED_STORAGE_DIR="storage/generated"

# 文生图 Provider（默认 gemini，可选 gemini/openai/gemini_http）
AI_PROVIDER="gemini"
IMAGE_GENERATION_PROVIDER=""

# OpenAI 兼容接口配置（仅文生图使用，IMAGE_GENERATION_PROVIDER=openai 时必填 OPENAI_API_KEY）
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1"

# Gemini 直连配置（仅文生图使用，IMAGE_GENERATION_PROVIDER=gemini 时需要 GEMINI_API_KEY）
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Gemini HTTP endpoint（仅文生图使用，IMAGE_GENERATION_PROVIDER=gemini_http）
GEMINI_HTTP_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_HTTP_API_KEY=""
GEMINI_HTTP_IMAGE_MODEL="gemini-3-pro-image-preview"
GEMINI_HTTP_AUTH_MODE=""
